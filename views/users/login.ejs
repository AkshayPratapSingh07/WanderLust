<% layout('/layouts/boilerplate') %>

<div
  class="container d-flex justify-content-center align-items-center signup-container"
>
  <div class="card shadow-lg p-4 signup-card">
    <h2 class="text-center mb-4 signup-title">Login to Your Account</h2>

    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label class="form-label fw-semibold">Username</label>
        <input type="text" class="form-control" name="username" required />
        <div class="invalid-feedback">Username is required</div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Password</label>
        <input type="password" class="form-control" name="password" required />
        <div class="invalid-feedback">Password is required</div>
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-primary">Login</button>
      </div>

      <p class="Nsignup-text">
        Don't have an account?
        <a href="/signup" class="Nsignup-link">Sign Up</a>
      </p>
    </form>
  </div>
</div>
