<% layout('/layouts/boilerplate') -%>

<div class="filters-wrapper">

  <!-- LEFT: Filters -->
  <div class="filters">

    <a href="/listings?category=Trending"
       class="filter <%= selectedCategory.includes('Trending') ? 'active' : '' %>">
      <i class="fa-solid fa-fire"></i><p>Trending</p>
    </a>

  

    <a href="/listings?category=Iconic cities"
       class="filter <%= selectedCategory.includes('Iconic cities') ? 'active' : '' %>">
      <i class="fa-solid fa-mountain-city"></i><p>Iconic cities</p>
    </a>

    <a href="/listings?category=Mountains"
       class="filter <%= selectedCategory.includes('Mountains') ? 'active' : '' %>">
      <i class="fa-solid fa-mountain"></i><p>Mountains</p>
    </a>

    <a href="/listings?category=Castles"
       class="filter <%= selectedCategory.includes('Castles') ? 'active' : '' %>">
      <i class="fa-brands fa-fort-awesome"></i><p>Castles</p>
    </a>

    <a href="/listings?category=Amazing pools"
       class="filter <%= selectedCategory.includes('Amazing pools') ? 'active' : '' %>">
      <i class="fa-solid fa-person-swimming"></i><p>Amazing pools</p>
    </a>

    <a href="/listings?category=Campgrounds"
       class="filter <%= selectedCategory.includes('Campgrounds') ? 'active' : '' %>">
      <i class="fa-solid fa-campground"></i><p>Campgrounds</p>
    </a>

    <a href="/listings?category=Farm"
       class="filter <%= selectedCategory.includes('Farm') ? 'active' : '' %>">
      <i class="fa-solid fa-tractor"></i><p>Farm</p>
    </a>

     <a href="/listings?category=Beach"
       class="filter <%= selectedCategory.includes('Beach') ? 'active' : '' %>">
      <i class="fa-solid fa-umbrella-beach"></i><p>Beach</p>
    </a>
    <a href="/listings?category=Luxe"
       class="filter <%= selectedCategory.includes('Luxe') ? 'active' : '' %>">
      <i class="fa-solid fa-crown"></i><p>Luxe</p>
    </a>


<div class="tax-toggle d-flex align-items-center">
  <div class="form-check form-switch">
    <input class="form-check-input" type="checkbox" id="taxSwitch">
    <label class="form-check-label" for="taxSwitch">
      Show prices with taxes and fees
    </label>
  </div>
</div>
  </div>

 
 

</div>



<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 g-4">

  <% if (allListings.length === 0) { %>
    <div class="col-12">
      <div class="alert alert-info text-center">
      <div class="no-results">
  <div class="no-results-box">
    <i class="fa-solid fa-face-sad-tear"></i>
    <h3>No listings found</h3>
    <p>
      No listings found for the selected category.<br />
      Try exploring other categories or check back later!
    </p>
    <a href="/listings" class="btn-explore">Explore Listings</a>
  </div>
</div>
       
      </div>
    </div>
  <% } %>

  <% for (let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="card-link">

        <div class="card">
          <img src="<%= listing.image.url %>" class="card-img-top">

          <div class="card-body">
            <p class="card-text">
              <%= listing.title %><br>
              ₹ <%= listing.price.toLocaleString('en-IN') %>/night
              <i class="taxInfo"> +18% GST</i>
            </p>
          </div>
        </div>

      </a>
    </div>
  <% } %>

</div>

